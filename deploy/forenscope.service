[Unit]
Description=ForenScope Gunicorn Service
After=network.target postgresql.service

[Service]
User=forenscope
Group=www-data
WorkingDirectory=/opt/forenscope
EnvironmentFile=/opt/forenscope/.env
ExecStart=/opt/forenscope/venv/bin/gunicorn \
    --workers 3 \
    --bind 127.0.0.1:8000 \
    --timeout 120 \
    --log-file /opt/forenscope/logs/gunicorn.log \
    config.wsgi:application
Restart=always

[Install]
WantedBy=multi-user.target
