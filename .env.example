# -------------------------------------------------------
# ForenScope — Environment Variables Example
# Copy this file to .env and fill in all values.
# NEVER commit the real .env to version control.
# -------------------------------------------------------

# ---- Django core ----
DJANGO_SECRET_KEY=django-insecure-change-this-in-production
DJANGO_DEBUG=False
# Development: config.settings.development
# Production:  config.settings.production
DJANGO_SETTINGS_MODULE=config.settings.production
# Comma-separated list of allowed hostnames / IPs (no spaces)
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,YOUR_SERVER_IP

# ---- Database (PostgreSQL 16) ----
DB_NAME=forenscope_db
DB_USER=forenscope
DB_PASSWORD=strong_password_here
DB_HOST=localhost
DB_PORT=5432

# ---- Storage ----
# Absolute paths are recommended in production
MEDIA_ROOT=media
STATIC_ROOT=staticfiles
